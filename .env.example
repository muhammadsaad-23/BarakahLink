# ─── Frontend environment variables ──────────────────────────────────────────
# These are prefixed with VITE_ to be exposed to the browser bundle.

# In local development this is NOT needed — Vite proxies /api to localhost:5001.
# In production (Vercel), set this to your deployed backend URL.
# Example: https://barakahlink-api.railway.app
VITE_API_BASE_URL=
