# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:    postgresql://postgres:postgres@localhost:5432/barakahlink
# Neon:     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/barakahlink?sslmode=require
# Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barakahlink"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# ─── AI ───────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ─── Frontend ─────────────────────────────────────────────────────────────────
# In dev this is http://localhost:3000; in prod it's your Vercel URL
FRONTEND_URL="http://localhost:3000"

# ─── SMS / Twilio (all optional — app runs without these) ─────────────────────
ENABLE_SMS=false
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
