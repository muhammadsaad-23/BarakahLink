{
  "name": "barakahlink",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,FE -c cyan,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend-api && npm run dev",
    "build": "vite build",
    "build:backend": "cd backend-api && npm run build",
    "preview": "vite preview",
    "prisma:migrate": "cd backend-api && npm run prisma:migrate",
    "prisma:seed": "cd backend-api && npm run prisma:seed",
    "prisma:studio": "cd backend-api && npm run prisma:studio"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
